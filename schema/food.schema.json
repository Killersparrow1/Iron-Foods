{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Indian Food Nutrition Schema",
  "description": "Canonical definition for a food item in Iron Foods.",
  "type": "object",
  "properties": {
    "id": { "type": "string", "description": "Unique identifier, slug-format (e.g., 'puttu-rice')." },
    "names": {
      "type": "object",
      "description": "Multilingual names for the food item.",
      "properties": {
        "en": { "type": "string", "description": "English name." },
        "ta": { "type": "string", "description": "Tamil name." },
        "ml": { "type": "string", "description": "Malayalam name." },
        "kn": { "type": "string", "description": "Kannada name." },
        "te": { "type": "string", "description": "Telugu name." }
      },
      "required": ["en"]
    },
    "aliases": { "type": "array", "items": { "type": "string" }, "description": "Alternative names or common misspellings." },
    "states": { "type": "array", "items": { "type": "string" }, "description": "Regional association." },
    "category": { "type": "string", "description": "Food category (e.g., 'breakfast', 'main')." },
    "serving_g": { "type": "number", "description": "Reference serving size in grams." },
    "nutrition": {
      "type": "object",
      "properties": {
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" },
        "fiber": { "type": "number" }
      },
      "required": ["calories", "protein", "carbs", "fat", "fiber"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "source_reference": { "type": "string" },
        "source_reliability": { "type": "string", "enum": ["institutional", "cited", "community"] }
      },
      "required": ["source", "source_reference", "source_reliability"]
    }
  },
  "required": ["id", "names", "serving_g", "nutrition", "metadata"]
}
